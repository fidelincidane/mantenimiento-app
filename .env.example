# Configuración para producción
# Copia este archivo como .env y completa los valores

# Genera una nueva secret key con: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=tu_secret_key_aqui

# Cambia a False en producción
DEBUG=False

# Tu dominio en Render (ej: mi-app.onrender.com)
ALLOWED_HOSTS=tu-dominio.onrender.com

# Base de datos PostgreSQL (crea una en Render)
# DATABASE_URL=postgres://usuario:password@hostname:5432/nombre_db

# Cloudinary (gratis hasta 25GB)
# Regístrate en cloudinary.com y obtiene tus credenciales:
# CLOUDINARY_CLOUD_NAME=tu_cloud_name
# CLOUDINARY_API_KEY=tu_api_key
# CLOUDINARY_API_SECRET=tu_api_secret
